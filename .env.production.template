# ═══════════════════════════════════════════════════════════════════
# M.O.N.O.L.I.T.H. — Production Environment Template
# Sports Event Contract Trading System
# Section 10.1 — NEVER COMMIT WITH REAL VALUES
# Copy to .env.production and fill in secrets
# ═══════════════════════════════════════════════════════════════════

# ── Kalshi (REQUIRED — primary data + trading) ───────────────────
KALSHI_API_KEY=CHANGE_ME
KALSHI_API_SECRET=CHANGE_ME
KALSHI_MODE=paper                    # paper | live

# ── Sports Data (REQUIRED — these are free) ──────────────────────
FOOTBALL_DATA_KEY=CHANGE_ME          # football-data.org (FREE, 600 req/hour)
CFBD_API_KEY=CHANGE_ME               # collegefootballdata.com (FREE, generous)

# ── Sports Data (OPTIONAL — backup sources only) ─────────────────
ODDS_API_KEY=                        # OPTIONAL: the-odds-api.com (500/month, backup only)
API_FOOTBALL_KEY=                    # OPTIONAL: api-football.com (100/day, backup only)

# ── Discord (REQUIRED — operator alerts) ─────────────────────────
DISCORD_WEBHOOK_URL=CHANGE_ME

# ── Database ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://monolith:CHANGE_ME@postgres:5432/monolith

# ── Infrastructure (REQUIRED) ───────────────────────────────────
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_ILP_PORT=9009
QUESTDB_PG_PORT=8812
QUESTDB_URL=http://questdb:9000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── Fund (REQUIRED — capital management) ─────────────────────────
INITIAL_CAPITAL=20
KELLY_FRACTION=0.25
DEFAULT_RESERVE_PCT=60

# ── Admin Auth (REQUIRED — terminal dashboard login) ─────────────
MONOLITH_JWT_SECRET=CHANGE_ME_jwt_secret_minimum_64_chars
ADMIN_USERNAME=shmookington
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── API Server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=https://yourdomain.com
API_RATE_LIMIT_RPM=120

# ── WebSocket ────────────────────────────────────────────────────
WS_API_KEY=CHANGE_ME_ws_api_key

# ── Monitoring ───────────────────────────────────────────────────
LOKI_URL=http://loki:3100/loki/api/v1/push

# ── Environment ──────────────────────────────────────────────────
MONOLITH_MODE=live
MONOLITH_LOG_LEVEL=INFO

# ── Domains (for Nginx/SSL) ─────────────────────────────────────
DOMAIN_DASHBOARD=terminal.monolith.app
DOMAIN_API=api.monolith.app
DOMAIN_GRAFANA=grafana.monolith.app
