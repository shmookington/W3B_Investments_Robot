# W3B Smart Contracts — Environment Variables
# ⚠️ DO NOT COMMIT THIS FILE TO GIT

# ─── Deployer ───
# Generate with: cast wallet new
DEPLOYER_PRIVATE_KEY=0x_YOUR_DEPLOYER_PRIVATE_KEY_HERE

# ─── RPC URLs ───
# Base Sepolia (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Base Mainnet
BASE_MAINNET_RPC_URL=https://mainnet.base.org
# Alternative: use Alchemy/Infura for higher rate limits
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Contract Verification ───
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ─── External Addresses (Base Mainnet) ───
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDY_ADDRESS=0x0000000000000000000000000000000000000000
CHAINLINK_ETH_USD=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70
CHAINLINK_BTC_USD=0xCCADC697c55bBb68dc5bCdf8d3CBe83CdD4E071E

# ─── Multisig ───
MULTISIG_ADDRESS=0x_YOUR_GNOSIS_SAFE_ADDRESS_HERE
TREASURY_ADDRESS=0x_YOUR_TREASURY_ADDRESS_HERE
PERSONAL_WALLET=0x_YOUR_PERSONAL_WALLET_HERE
